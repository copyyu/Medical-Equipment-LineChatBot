# ── LINE Messaging API ─────────────────────────────────────
LINE_CHANNEL_TOKEN=your_line_channel_token
LINE_CHANNEL_SECRET=your_line_channel_secret

# ── Server ─────────────────────────────────────────────────
PORT=3000
BASE_URL=http://localhost:3000

# App environment: "production" emits JSON logs, anything else emits text logs
APP_ENV=development
# Log level: debug | info | warn | error
LOG_LEVEL=info

# ── PostgreSQL ─────────────────────────────────────────────
DB_HOST=db
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=medical_equipment

# Connection Pool (production-grade defaults)
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME_MIN=30

# ── Redis ──────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── OCR API (optional) ────────────────────────────────────
OCR_API_URL=

# ── Contact Info ───────────────────────────────────────────
CONTACT_CENTER_NAME=ศูนย์เครื่องมือแพทย์
CONTACT_PHONE=
CONTACT_EMAIL=
CONTACT_EMERGENCY_PHONE=
CONTACT_WORKING_HOURS=จ-ศ 08:00-17:00
