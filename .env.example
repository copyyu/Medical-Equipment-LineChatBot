# ── LINE Messaging API ─────────────────────────────────────
LINE_CHANNEL_TOKEN=your_line_channel_token
LINE_CHANNEL_SECRET=your_line_channel_secret

# ── Server ─────────────────────────────────────────────────
PORT=3000
BASE_URL=http://localhost:3000

# App environment: "production" emits JSON logs, anything else emits text logs
APP_ENV=development
# Log level: debug | info | warn | error
LOG_LEVEL=info

# CORS allow-list (comma-separated). Use specific origins in production, not "*"
ALLOWED_ORIGINS=*

# Timeouts (seconds)
HTTP_READ_TIMEOUT_SEC=15
HTTP_WRITE_TIMEOUT_SEC=120
HTTP_IDLE_TIMEOUT_SEC=120
SHUTDOWN_TIMEOUT_SEC=15
LINE_API_TIMEOUT_SEC=10
OCR_API_TIMEOUT_SEC=90

# ── Admin bootstrap ────────────────────────────────────────
# The first super-admin is created on startup only if no admin exists yet.
# /api/admin/register is restricted to super-admins, so set these on first deploy.
ADMIN_BOOTSTRAP_USERNAME=
ADMIN_BOOTSTRAP_PASSWORD=
ADMIN_BOOTSTRAP_EMAIL=
ADMIN_BOOTSTRAP_FULLNAME=Super Admin

# ── PostgreSQL ─────────────────────────────────────────────
DB_HOST=db
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=medical_equipment

# Connection Pool (production-grade defaults)
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME_MIN=30

# ── Redis ──────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── OCR API (optional) ────────────────────────────────────
OCR_API_URL=

# ── Initial Admin (provisioned at startup if no admin exists) ──
# Admin registration is authenticated-only; set these to bootstrap the first
# account. Leave blank once at least one admin exists.
INITIAL_ADMIN_USERNAME=
INITIAL_ADMIN_EMAIL=
INITIAL_ADMIN_PASSWORD=
INITIAL_ADMIN_FULLNAME=System Administrator

# ── Contact Info ───────────────────────────────────────────
CONTACT_CENTER_NAME=ศูนย์เครื่องมือแพทย์
CONTACT_PHONE=
CONTACT_EMAIL=
CONTACT_EMERGENCY_PHONE=
CONTACT_WORKING_HOURS=จ-ศ 08:00-17:00
